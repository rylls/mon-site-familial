# URL de ton projet Supabase (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé "service_role" (Settings > API > service_role secret)
# ATTENTION : cette clé est secrète, ne jamais la mettre en NEXT_PUBLIC_ ni la commiter
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mot de passe partagé pour accéder au site
SITE_PASSWORD=wouchijr
