# URL de ton projet Supabase (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé "service_role" (Settings > API > service_role secret)
# ATTENTION : cette clé est secrète, ne jamais la mettre en NEXT_PUBLIC_ ni la commiter
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mot de passe partagé pour accéder au site
SITE_PASSWORD=wouchijr

# Mêmes valeurs que ci-dessus mais exposées au navigateur (Settings > API >
# Project URL / clé "anon public" ou "publishable" — conçue pour être
# publique, protégée par les policies RLS de lecture seule des migrations).
# Nécessaires pour la synchro en direct entre appareils (Realtime).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
